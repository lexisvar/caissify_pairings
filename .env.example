# Copy this file to `.env` and fill in your secrets.
# `.env` is git-ignored — never commit it.

# --- PyPI release ------------------------------------------------------
# Generate an API token at: https://pypi.org/manage/account/token/
# Scope it to the `caissify-pairings` project, not account-wide.
# Format must start with `pypi-`.
PYPI_API_TOKEN=pypi-REPLACE_ME

# Optional: upload to TestPyPI first (https://test.pypi.org/manage/account/token/)
# TESTPYPI_API_TOKEN=pypi-REPLACE_ME
